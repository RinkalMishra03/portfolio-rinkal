# ==============================================================================
# Environment Variables Configuration Template
# Create a .env file locally with these variables set.
# ==============================================================================

# Application Running Port (Defaults to 3000 in this container environment)
PORT=3000

# ------------------------------------------------------------------------------
# Gemini API Configuration
# ------------------------------------------------------------------------------
# Required for any server-side Gemini features (automatically injected by AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# Database Configurations (MongoDB Atlas)
# ------------------------------------------------------------------------------
# Your complete MongoDB Atlas connection URI string:
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_uri_here

# ------------------------------------------------------------------------------
# Email Service (Nodemailer / Gmail SMTP)
# ------------------------------------------------------------------------------
# Host of the SMTP server (default is smtp.gmail.com)
SMTP_HOST=smtp.gmail.com

# Port of the SMTP server (587 for TLS, 465 for SSL)
SMTP_PORT=587

# Your Gmail address used to authenticate and send the mail
SMTP_USER=your-email@gmail.com

# Your 16-character Gmail App Password (NOT your regular password!)
SMTP_PASS=your-16-character-app-password

# The destination mailbox where you want to receive message notifications
RECEIVER_EMAIL=your-email@gmail.com

# ------------------------------------------------------------------------------
# Administration Secret Key
# ------------------------------------------------------------------------------
# Custom bearer token key to authenticate Admin GET and DELETE endpoints
# Pass this in the 'Authorization: Bearer <key>' or 'x-admin-key: <key>' headers
ADMIN_SECRET=admin_secret_123
